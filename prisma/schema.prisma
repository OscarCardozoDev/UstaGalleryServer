generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Credentials {
  uid        String     @id @default(uuid())
  email      String     @unique @db.VarChar(100) 
  password   String     @db.Text

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}


model UserTypes {
  id          String     @id @default(uuid())
  name        String     @db.VarChar(30)
  Users       Users[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Users {
  uid              String     @id
  userType         UserTypes  @relation(fields: [userTypeId], references: [id])
  userTypeId       String
  telNumber        String     @db.VarChar(12)
  name             String     @db.VarChar(25)
  lastName         String     @db.VarChar(25)
  isActive         Boolean    @default(true)

  // Relaciones
  groups           Groups[]   @relation("GroupMembers")
  profesor         Groups[]   @relation("GroupProfesor")
 
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  finishedAt       DateTime?
}

model Groups {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(30)

  // Profesor del grupo
  profesor     Users   @relation("GroupProfesor", fields: [profesorId], references: [uid])
  profesorId   String

  // Estudiantes del grupo
  members      Users[] @relation("GroupMembers")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
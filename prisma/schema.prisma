generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////
enum Category {
  ARTES
  TEATRO
  DANZAS
  MUSICA
  CANTO
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum EventType {
  EXHIBITION
  WORKSHOP
  PERFORMANCE
  CONFERENCE
  OTHER
}

enum EventPhotoType {
  HERO
  PROMO
  MEMORY
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

//////////////////////////////////////////////////////
// USER TYPES
//////////////////////////////////////////////////////

model UserTypes {
  uid        String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(30)

  users      Users[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model Users {
  uid            String    @id @unique @db.Uuid
  name           String    @db.VarChar(30)
  lastName       String    @db.VarChar(30)
  username       String    @db.VarChar(30) @unique
  description    String?   @db.VarChar(500)
     
  gender         String    @db.VarChar(3)
  idCard         String    @db.VarChar(12) @unique
  degree         String    @db.VarChar(120)
  semester       String    @db.VarChar(2)
  telNumber      String    @db.VarChar(12)
     
  isActive       Boolean   @default(true)

  // RELACIONES
  userType       UserTypes @relation(fields: [userTypeId], references: [uid])
  userTypeId     String    @db.Uuid
  photo          Photos?   @relation("UserPhoto", fields: [photoId], references: [uid])
  photoId        String?   @unique @db.Uuid

  groups         UsersGroups[]
  products       UserProduct[]
  managedGroups  Groups[]  @relation("GroupProfesor")
  createdEvents  Events[]  @relation("EventCreator")
  attendance     Attendance[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  finishAt     DateTime?
}

model Credentials {
  uid              String    @id @default(uuid()) @db.Uuid
  mail             String    @db.VarChar(100) @unique
  password         String    @db.VarChar(250)
  isEmailVerified  Boolean   @default(false)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  finishedAt       DateTime?
}

model VerificationCodes {
  uid           String    @id @default(uuid()) @db.Uuid
  credentialUid String    @db.Uuid
  code          String    @db.VarChar(6)
  expiresAt     DateTime
  usedAt        DateTime?

  createdAt     DateTime  @default(now())

  @@index([credentialUid])
}

//////////////////////////////////////////////////////
// GROUPS
//////////////////////////////////////////////////////

model Groups {
  uid          String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(100) // Ej: "Danza Folclórica"
  category     Category @default(ARTES)
  isActive     Boolean  @default(true)

  // Profesor  (Sin @unique para permitir 1 profesor -> N grupos)
  profesor     Users    @relation("GroupProfesor", fields: [profesorId], references: [uid])
  profesorId   String   @db.Uuid

  users        UsersGroups[]
  products     Products[]
  events       GroupEvent[]
  styles       Styles[]
  invitations  EventInvitation[]
  schedules    Schedule[]
  classes      Classes[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UsersGroups {
  uid       String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  groupId   String   @db.Uuid

  user      Users    @relation(fields: [userId], references: [uid])
  group     Groups   @relation(fields: [groupId], references: [uid])

  createdAt DateTime @default(now())

  @@unique([userId, groupId])
}

//////////////////////////////////////////////////////
// PRODUCTS
//////////////////////////////////////////////////////

model Products {
  uid          String        @id @default(uuid()) @db.Uuid
  name         String        @db.VarChar(100)
  description  String        @db.VarChar(500)
  
  status       ProductStatus @default(PENDING)
  feedback     String?       @db.VarChar(300)
  isActive     Boolean       @default(true)

  price        Decimal?      @db.Decimal(10,2)
  isSold       Boolean       @default(false)
  madeAt       DateTime
  
  groupId      String        @db.Uuid
  group        Groups        @relation(fields: [groupId], references: [uid])

  styles       ProductStyle[]
  photos       ProductPhoto[]
  events       EventProduct[]
  authors      UserProduct[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

//////////////////////////////////////////////////////
// STYLES
//////////////////////////////////////////////////////

model Styles {
  uid          String          @id @default(uuid()) @db.Uuid
  name         String          @db.VarChar(30)
  description  String          @db.VarChar(300)
  category     Category        @default(ARTES)
  isActive     Boolean         @default(true)

  products     ProductStyle[]

    groupId      String          @db.Uuid
  group        Groups          @relation(fields: [groupId], references: [uid])

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model ProductStyle {
  uid        String   @id @default(uuid()) @db.Uuid
  productId  String   @db.Uuid
  styleId    String   @db.Uuid

  product    Products @relation(fields: [productId], references: [uid])
  style      Styles   @relation(fields: [styleId], references: [uid])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, styleId])
}

//////////////////////////////////////////////////////
// PHOTOS
//////////////////////////////////////////////////////

model Photos {
  uid        String         @id @default(uuid()) @db.Uuid
  name       String         @db.VarChar(100)
  url        String         @db.VarChar(500)

  products   ProductPhoto[]
  events     EventPhoto[]
  user       Users?         @relation("UserPhoto")

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model ProductPhoto {
  uid        String    @id @default(uuid()) @db.Uuid
  productId  String    @db.Uuid
  photoId    String    @db.Uuid
  isMain     Boolean   @default(false)

  product    Products @relation(fields: [productId], references: [uid])
  photo      Photos   @relation(fields: [photoId], references: [uid])

  createdAt  DateTime  @default(now())

  @@unique([productId, photoId])
}

//////////////////////////////////////////////////////
// EVENTS
//////////////////////////////////////////////////////

model Events {
  uid          String      @id @default(uuid()) @db.Uuid
  name         String      @db.VarChar(100)
  description  String      @db.VarChar(1000)
  status       EventStatus @default(PENDING)
  feedback     String?     @db.VarChar(500)
  eventType    EventType   @default(EXHIBITION)
  startDate    DateTime
  endDate      DateTime?
  locationUrl  String?     @db.VarChar(500)
  isVirtual    Boolean     @default(false)
  streamingUrl String?     @db.VarChar(500)
  isActive     Boolean     @default(true)

  createdBy    Users       @relation("EventCreator", fields: [createdById], references: [uid])
  createdById  String      @db.Uuid

  products     EventProduct[]
  photos       EventPhoto[]
  groups       GroupEvent[]
  invitations  EventInvitation[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model EventProduct {
  uid        String    @id @default(uuid()) @db.Uuid
  productId  String    @db.Uuid
  eventId    String    @db.Uuid

  product    Products @relation(fields: [productId], references: [uid])
  event      Events   @relation(fields: [eventId], references: [uid])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([productId, eventId])
}

model EventInvitation {
  uid         String           @id @default(uuid()) @db.Uuid
  eventId     String           @db.Uuid
  groupId     String           @db.Uuid
  status      InvitationStatus @default(PENDING)

  event       Events  @relation(fields: [eventId], references: [uid])
  group       Groups  @relation(fields: [groupId], references: [uid])

  sentAt      DateTime  @default(now())
  respondedAt DateTime?
  updatedAt   DateTime  @updatedAt  

  @@unique([eventId, groupId])
}

model EventPhoto {
  uid        String         @id @default(uuid()) @db.Uuid
  eventId    String         @db.Uuid
  photoId    String         @db.Uuid
  photoType  EventPhotoType @default(PROMO)

  event      Events  @relation(fields: [eventId], references: [uid])
  photo      Photos  @relation(fields: [photoId], references: [uid])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([eventId, photoId])
}

//////////////////////////////////////////////////////
// USERS ↔ PRODUCTS (AUTHOR)
//////////////////////////////////////////////////////

model UserProduct {
  uid        String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  productId  String    @db.Uuid
  isAuthor   Boolean   @default(false)

  user       Users     @relation(fields: [userId], references: [uid])
  product    Products  @relation(fields: [productId], references: [uid])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, productId])
}

//////////////////////////////////////////////////////
// GROUPS ↔ EVENTS
//////////////////////////////////////////////////////

model GroupEvent {
  uid        String   @id @default(uuid()) @db.Uuid
  groupId    String   @db.Uuid
  eventId    String   @db.Uuid

  group      Groups   @relation(fields: [groupId], references: [uid])
  event      Events   @relation(fields: [eventId], references: [uid])

  createdAt  DateTime @default(now())

  @@unique([groupId, eventId])
}

//////////////////////////////////////////////////////
// SCHEDULE & CLASSES
//////////////////////////////////////////////////////

model Schedule {
  uid        String   @id @default(uuid()) @db.Uuid
  groupId    String   @db.Uuid
  dayOfWeek  Int      // 0=Dom, 1=Lun, 2=Mar, 3=Mié, 4=Jue, 5=Vie, 6=Sáb
  startTime  String   @db.VarChar(5)  // "HH:mm"
  endTime    String   @db.VarChar(5)  // "HH:mm"
  isActive   Boolean  @default(true)

  group      Groups   @relation(fields: [groupId], references: [uid])
  classes    Classes[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Classes {
  uid        String    @id @default(uuid()) @db.Uuid
  groupId    String    @db.Uuid
  scheduleId String?   @db.Uuid  // null = clase manual
  date       DateTime
  startTime  String    @db.VarChar(5)  // "HH:mm"
  endTime    String    @db.VarChar(5)  // "HH:mm"
  topic      String?   @db.VarChar(500)
  review     String?   @db.VarChar(1000)
  isActive   Boolean   @default(true)

  group      Groups    @relation(fields: [groupId], references: [uid])
  schedule   Schedule? @relation(fields: [scheduleId], references: [uid])
  attendance Attendance[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Attendance {
  uid      String   @id @default(uuid()) @db.Uuid
  classId  String   @db.Uuid
  userId   String   @db.Uuid
  takenAt  DateTime @default(now())

  class    Classes  @relation(fields: [classId], references: [uid])
  user     Users    @relation(fields: [userId], references: [uid])

  @@unique([classId, userId])
}

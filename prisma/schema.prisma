generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// USER TYPES
//////////////////////////////////////////////////////

model UserTypes {
  uid        String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(30)

  users      Users[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model Users {
  uid          String        @id @unique @db.Uuid
  name         String        @db.VarChar(30)
  lastName     String        @db.VarChar(30)
  telNumber    String        @db.VarChar(12)
  isActive     Boolean       @default(true)
  isProfesor   Boolean       @default(false)

  userType     UserTypes     @relation(fields: [userTypeId], references: [uid])
  userTypeId   String        @db.Uuid

  groups        UsersGroups[]
  products      UserProduct[]
  profesorGroup Groups? @relation("GroupProfesor")


  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  finishAt     DateTime?
}

model Credentials {
  uid        String     @id @default(uuid()) @db.Uuid
  mail       String     @db.VarChar(100) @unique
  password   String     @db.VarChar(250)

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  finishedAt DateTime?  @updatedAt
}

//////////////////////////////////////////////////////
// GROUPS
//////////////////////////////////////////////////////

model Groups {
  uid        String        @id @default(uuid()) @db.Uuid
  name       String        @db.VarChar(100)

  // Profesor del grupo
  profesor     Users   @relation("GroupProfesor", fields: [profesorId], references: [uid])
  profesorId   String  @unique @db.Uuid

  users      UsersGroups[]
  products   Products[]
  events     GroupEvent[]
  styles     Styles[]

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model UsersGroups {
  uid       String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  groupId   String   @db.Uuid

  user      Users    @relation(fields: [userId], references: [uid])
  group     Groups   @relation(fields: [groupId], references: [uid])

  createdAt DateTime @default(now())

  @@unique([userId, groupId])
}

//////////////////////////////////////////////////////
// PRODUCTS
//////////////////////////////////////////////////////

model Products {
  uid          String          @id @default(uuid()) @db.Uuid
  name         String          @db.VarChar(30)
  description  String          @db.VarChar(300)
  price        Decimal?        @db.Decimal(8,2)
  isSolded      Boolean         @default(false)
  isReviewed   Boolean         @default(false)
  madeAt       DateTime
  groupId      String          @db.Uuid
  imageId      String?         @db.Uuid

  group        Groups          @relation(fields: [groupId], references: [uid])

  styles       ProductStyle[]
  photos       ProductPhoto[]
  events       EventProduct[]
  authors      UserProduct[]

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

//////////////////////////////////////////////////////
// STYLES
//////////////////////////////////////////////////////

model Styles {
  uid          String          @id @default(uuid()) @db.Uuid
  name         String          @db.VarChar(30)
  description  String          @db.VarChar(300)

  products     ProductStyle[]

  groupId      String          @db.Uuid
  group        Groups          @relation(fields: [groupId], references: [uid])

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model ProductStyle {
  uid        String   @id @default(uuid()) @db.Uuid
  productId  String   @db.Uuid
  styleId    String   @db.Uuid

  product    Products @relation(fields: [productId], references: [uid])
  style      Styles   @relation(fields: [styleId], references: [uid])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, styleId])
}

//////////////////////////////////////////////////////
// PHOTOS
//////////////////////////////////////////////////////

model Photos {
  uid        String         @id @default(uuid()) @db.Uuid
  name       String         @db.VarChar(100)
  url        String         @db.VarChar(300)

  products   ProductPhoto[]
  events     EventPhoto[]

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model ProductPhoto {
  uid        String    @id @default(uuid()) @db.Uuid
  productId  String    @db.Uuid
  photoId    String    @db.Uuid
  isMain     Boolean   @default(false)

  product    Products @relation(fields: [productId], references: [uid])
  photo      Photos   @relation(fields: [photoId], references: [uid])

  createdAt  DateTime  @default(now())

  @@unique([productId, photoId])
}

//////////////////////////////////////////////////////
// EVENTS
//////////////////////////////////////////////////////

model Events {
  uid          String          @id @default(uuid()) @db.Uuid
  name         String          @db.VarChar(30)
  description  String
  date         DateTime

  products     EventProduct[]
  photos       EventPhoto[]
  groups       GroupEvent[]

  createdAt    DateTime        @default(now())
}

model EventProduct {
  uid        String    @id @default(uuid()) @db.Uuid
  productId  String    @db.Uuid
  eventId    String    @db.Uuid

  product    Products @relation(fields: [productId], references: [uid])
  event      Events   @relation(fields: [eventId], references: [uid])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([productId, eventId])
}

model EventPhoto {
  uid        String   @id @default(uuid()) @db.Uuid
  eventId    String   @db.Uuid
  photoId    String   @db.Uuid
  isHero     Boolean  @default(false)

  event      Events  @relation(fields: [eventId], references: [uid])
  photo      Photos  @relation(fields: [photoId], references: [uid])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([eventId, photoId])
}

//////////////////////////////////////////////////////
// USERS ↔ PRODUCTS (AUTHOR)
//////////////////////////////////////////////////////

model UserProduct {
  uid        String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  productId  String    @db.Uuid
  isAuthor   Boolean   @default(false)

  user       Users     @relation(fields: [userId], references: [uid])
  product    Products  @relation(fields: [productId], references: [uid])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, productId])
}

//////////////////////////////////////////////////////
// GROUPS ↔ EVENTS
//////////////////////////////////////////////////////

model GroupEvent {
  uid        String   @id @default(uuid()) @db.Uuid
  groupId    String   @db.Uuid
  eventId    String   @db.Uuid

  group      Groups   @relation(fields: [groupId], references: [uid])
  event      Events   @relation(fields: [eventId], references: [uid])

  createdAt  DateTime @default(now())

  @@unique([groupId, eventId])
}
